# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/collabhub

# ─── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── SMTP (Email) ─────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending (dev fallback: logs to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=CollabHub
SMTP_FROM_EMAIL=noreply@collabhub.com

# ─── Frontend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── WebRTC (optional) ────────────────────────────────
# Used if you provide TURN credentials via API
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=
